# CodeSila Backend Environment Variables
# Copy this file to .env and fill in values

# Database
POSTGRES_USER=codesila
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=codesila_db
DATABASE_URL=postgresql://codesila:changeme_strong_password@localhost:5432/codesila_db?schema=public

# Auth
JWT_SECRET=changeme_generate_with_openssl_rand_base64_32

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins (use * only in development)
CORS_ORIGINS=http://localhost:5173

# OpenAI (required for assistant module)
OPENAI_API_KEY=

# Redis (optional)
REDIS_URL=
